# Template file — do NOT put real keys here. Copy to .env and fill in there.
# .env is gitignored; .env.example is committed.

# Anthropic API key for the reasoning agents (Brief Parser, Brand Translator, Creative Director, QA)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI key for Nano Banana Pro (Gemini 3 Pro Image)
GOOGLE_API_KEY=...

# Optional: model overrides
CLAUDE_MODEL=claude-opus-4-5

# Nano Banana Pro is 'gemini-3-pro-image-preview'. If your key doesn't have access yet,
# fall back to Nano Banana: 'gemini-2.5-flash-image-preview' (or 'gemini-2.5-flash-image').
# Use `python cli.py models` to see which image models your key can access.
NANO_BANANA_MODEL=gemini-3-pro-image-preview
